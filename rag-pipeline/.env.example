# Service URLs use docker-compose service names by default.
OLLAMA_URL=http://ollama:11434
CHROMA_URL=http://chroma:8000

# Models (must be pulled into Ollama before use; the ollama-bootstrap service does this)
LLM_MODEL=llama3:8b
EMBED_MODEL=nomic-embed-text

# Server
PORT=3000

# Retrieval
TOP_K=8
RERANK=false
